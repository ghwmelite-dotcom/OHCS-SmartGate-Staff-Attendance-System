# Copy this file to .env in the same directory and fill in real values.
# .env is gitignored — never commit it.
# Both apps share the same Staff ID + PIN credentials.

# ─── URLs ──────────────────────────────────────────────────
VMS_URL=https://smartgate.ohcsghana.org
STAFF_URL=https://staff-attendance.ohcsghana.org

# ─── Shared credentials (Staff ID + PIN) ──────────────────
STAFF_ID=YOUR_STAFF_ID
STAFF_PIN=YOUR_4_DIGIT_PIN
