# Copy this file to .env in the same directory and fill in real values.
# .env is gitignored — never commit it.

# ─── SmartGate (VMS) admin / reception ─────────────────────
VMS_URL=https://ohcs-smartgate.pages.dev
VMS_EMAIL=receptionist@example.ohcs.gov.gh
VMS_PASSWORD=replace-me

# Optional — only needed if you want screenshots from a host's perspective
VMS_HOST_EMAIL=host@example.ohcs.gov.gh
VMS_HOST_PASSWORD=replace-me

# ─── Staff Attendance ──────────────────────────────────────
STAFF_URL=https://staff-attendance.pages.dev
